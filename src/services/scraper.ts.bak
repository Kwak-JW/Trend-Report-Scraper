import puppeteer from 'puppeteer';
import * as cheerio from 'cheerio';
import fs from 'fs';
import path from 'path';
import axios from 'axios';
import https from 'https';
import { parseISO, isAfter, isBefore, isEqual, isValid } from 'date-fns';
import { JobManager } from './jobManager.ts';

function extractKoreanDateFallback(text: string): Date | null {
    // try YYYY년 MM월 (일)
    const r2 = /(\d{4})년\s*(\d{1,2})월(?:\s*(\d{1,2})일)?/;
    let m = text.match(r2);
    if(m) return new Date(`${m[1]}-${m[2].padStart(2, '0')}-${m[3] ? m[3].padStart(2, '0') : '01'}`);
    
    // try YYYY. MM월
    const r3 = /(\d{4})\.\s*(\d{1,2})월/;
    m = text.match(r3);
    if(m) return new Date(`${m[1]}-${m[2].padStart(2, '0')}-01`);
    
    // try YYYY. M or YYYY. MM (Standard dot style without strict word boundaries)
    const r4 = /(\d{4})\.\s*(\d{1,2})/;
    m = text.match(r4);
    if(m) {
        const year = parseInt(m[1], 10);
        const month = parseInt(m[2], 10);
        if (year >= 1990 && year <= 2100 && month >= 1 && month <= 12) {
            return new Date(`${m[1]}-${m[2].padStart(2, '0')}-01`);
        }
    }
    
    return null;
}

export async function startScrapingJob(jobId: string) {
  const job = JobManager.getJob(jobId);
  if (!job) return;

  const { urls, startDate, endDate, localPath } = job.config;

  const isCancelled = () => {
    const freshJob = JobManager.getJob(jobId);
    return !freshJob || freshJob.status === 'cancelled';
  };

  try {
    JobManager.updateStatus(jobId, 'running');
    JobManager.addLog(jobId, 'info', `🚀 크롤링 작업을 시작합니다. 대상 URL 수: ${urls.length}개`);
    
    // Create directory
    if (!fs.existsSync(localPath)) {
      fs.mkdirSync(localPath, { recursive: true });
      JobManager.addLog(jobId, 'info', `📁 저장소 폴더 생성: ${localPath}`);
    }

    const startParsed = parseISO(startDate);
    const endParsed = parseISO(endDate);

    JobManager.addLog(jobId, 'info', `🔄 브라우저 엔진을 시작합니다...`);
    const browser = await puppeteer.launch({
      headless: true,
      args: [
        '--no-sandbox',
        '--disable-setuid-sandbox',
        '--disable-dev-shm-usage',
        '--disable-accelerated-2d-canvas',
        '--no-first-run',
        '--no-zygote',
        '--disable-gpu'
      ],
    });

    const allCandidateDetailLinks: { title: string, url: string, directDownloadUrl?: string }[] = [];

    for (const targetUrl of urls) {
      if (isCancelled()) {
        JobManager.addLog(jobId, 'warn', `⏹️ 수집 중단: 추가 타겟 사이트(${targetUrl}) 분석을 취소합니다.`);
        break;
      }
      
      JobManager.addLog(jobId, 'info', `🌐 타겟 사이트 분석: ${targetUrl}`);
      
      // Compute pages to crawl for this targetUrl using generic heuristic
      let pagesToCrawl: string[] = [];
      const u = new URL(targetUrl);
      let pageParam = '';
      let isZeroIndexed = false;
      let step = 1;
      const paginationKeywords = ['page', 'pg', 'pageidx', 'pageindex', 'pageno', 'startindex', 'offset'];
      
      for (const key of u.searchParams.keys()) {
          if (paginationKeywords.includes(key.toLowerCase())) {
              pageParam = key;
              const val = parseInt(u.searchParams.get(key) || '1', 10);
              if (val === 0) isZeroIndexed = true;
              if (key.toLowerCase() === 'startindex' || key.toLowerCase() === 'offset') { 
                  step = 10; 
              }
              break;
          }
      }

      if (!pageParam) {
          if (targetUrl.includes('kotra.or.kr')) {
              pageParam = 'pageNo';
          } else {
              pageParam = 'page'; // default generic fallback
          }
      }

      for (let i = 1; i <= 30; i++) {
          if (i === 1) {
              pagesToCrawl.push(targetUrl);
          } else {
              const u2 = new URL(targetUrl);
              let val = isZeroIndexed ? (i - 1) * step : i * step - (step - 1);
              u2.searchParams.set(pageParam, val.toString());
              pagesToCrawl.push(u2.toString());
          }
      }

      try {
        const page = await browser.newPage();
        await page.setUserAgent('Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36');
        await page.setExtraHTTPHeaders({
            'Accept-Language': 'ko-KR,ko;q=0.9,en-US;q=0.8,en;q=0.7'
        });
        await page.setRequestInterception(true);
        page.on('request', (req) => {
          if (['image', 'stylesheet', 'font', 'media'].includes(req.resourceType())) {
            req.abort();
          } else {
            req.continue();
          }
        });

        for (let pIdx = 0; pIdx < pagesToCrawl.length; pIdx++) {
            if (isCancelled()) {
                JobManager.addLog(jobId, 'warn', `⏹️ 수집 중단: 목록 탐색을 중단합니다.`);
                break;
            }
            const currentUrl = pagesToCrawl[pIdx];
            if (pIdx > 0) {
                JobManager.addLog(jobId, 'info', `  => 과거 데이터 탐색 (Page ${pIdx + 1})...`);
            }
            JobManager.addLog(jobId, 'info', `  => URL 조회: ${currentUrl}`);
            
            let html = '';
            let loadSuccess = false;
            for (let retry = 0; retry < 3; retry++) {
                try {
                    // Check if JS custom pageFunction paging is needed (e.g., KDI)
                    if (pIdx > 0 && currentUrl === targetUrl) {
                        const pNum = pIdx + 1;
                        const evalResult = await page.evaluate((p) => {
                            if (typeof (window as any).pageFunction === 'function') {
                                (window as any).pageFunction(p);
                                return true;
                            }
                            return false;
                        }, pNum);
                        
                        if (evalResult) {
                            JobManager.addLog(jobId, 'info', `     => [JS Paging] pageFunction(${pNum}) JS 페이징 함수 실행됨. 컨텐츠 로딩 대기...`);
                            await page.waitForSelector('.page_list-group, tbody, ul', { timeout: 10000 }).catch(() => {});
                            await new Promise(r => setTimeout(r, 1500));
                            html = await page.content();
                            loadSuccess = true;
                            break;
                        }
                    }

                    await page.goto(currentUrl, { waitUntil: 'domcontentloaded', timeout: 30000 });
                    // dynamic list loading wait (e.g. KOTRA, LGBR AJAX wait)
                    await page.waitForSelector('.nttTr, .board_list, .tbl_wrap, tbody, tr, li', { timeout: 6000 }).catch(() => {});
                    await new Promise(r => setTimeout(r, 2000)); // Additional safety buffer for client rendering
                    html = await page.content();
                    loadSuccess = true;
                    break;
                } catch (pe) {
                    JobManager.addLog(jobId, 'warn', `     ⚠️ 목록 페이지 로드 재시도 (${retry + 1}/3): ${pe instanceof Error ? pe.message : pe}`);
                    await new Promise(r => setTimeout(r, 2000));
                }
            }
            
            if (!loadSuccess) {
                JobManager.addLog(jobId, 'error', `     ❌ 목록 페이지 로드 실패, 대상 스킵: ${currentUrl}`);
                continue;
            }

            const $ = cheerio.load(html);
            
            if (pIdx === 0) {
                // Dynamically discover year/month based pagination if no generic pageParam is present in URL
                const hasYearSelect = $('select[name="year"]').length > 0;
                const hasMonthSelect = $('select[name="month"]').length > 0;
                const pageParamExists = paginationKeywords.some(k => currentUrl.toLowerCase().includes(k) || $('a').toArray().some(a => $(a).attr('href')?.toLowerCase().includes(k)));
                
                if (hasYearSelect && hasMonthSelect && !pageParamExists) {
                    JobManager.addLog(jobId, 'info', `  => 연도/월(Year/Month) 기반 아코디언/조회 폼 감지, 순회 방식을 변경합니다.`);
                    const startY = startParsed.getFullYear();
                    const startM = startParsed.getMonth() + 1;
                    const endY = endParsed.getFullYear();
                    const endM = endParsed.getMonth() + 1;
                    
                    const newPages = [];
                    for (let y = endY; y >= startY; y--) {
                        const mStart = (y === startY) ? startM : 1;
                        const mEnd = (y === endY) ? endM : 12;
                        for (let m = mEnd; m >= mStart; m--) {
                            const u = new URL(targetUrl);
                            u.searchParams.set('year', y.toString());
                            u.searchParams.set('month', m.toString().padStart(2, '0'));
                            if (u.toString() !== currentUrl) {
                                newPages.push(u.toString());
                            }
                        }
                    }
                    pagesToCrawl = [currentUrl, ...newPages].slice(0, 30);
                }
            }

            const dateRegex = /(\d{4})[-.]\s*(\d{2})[-.]\s*(\d{2})/;
            const candidateRowsRaw: { el: any, hasDate: boolean, parsedDate?: Date }[] = [];
            
            let oldestDateOnPage: Date | null = null;
            let foundValidDates = false;

            // Restrict selector scope to main contents region to filter out GNB, side banner or footer dates
            let mainContainer: any = $('body');
            const wrappers = [
                'section#contents', '.page_contents', '#content', '#contents', 'main', '.content', 
                '.sub_content', '#sub_content', '.contents', '.container', '.tbl_wrap', '.board_list'
            ];
            for (const wrapper of wrappers) {
                if ($(wrapper).length > 0) {
                    mainContainer = $(wrapper);
                    break;
                }
            }

            mainContainer.find('tr, li, dl, .item, .list_item, .card, .t_box, .rcnt_wrap, .board_list > div, .board_list > a').each((_, el) => {
               if ($(el).closest('nav, header, footer, .pagination, .gnb, #header, #footer').length > 0) return;
               
               const text = $(el).text();
               
               // exclude obvious irrelevants
               if(text.includes('영상 보고서') || text.includes('영상보고서')) return;

               const match = text.match(dateRegex);
               let parsedDate: Date | null = null;
               
               if (match) {
                 parsedDate = new Date(`${match[1]}-${match[2]}-${match[3]}`);
               } else {
                 parsedDate = extractKoreanDateFallback(text);
               }
               
               if (parsedDate && isValid(parsedDate)) {
                  foundValidDates = true;

                  const hasLink = $(el).find('a[href], button[onclick]').length > 0 || $(el).closest('a[href]').length > 0 || $(el).is('a[href]');
                  if (hasLink) {
                     if (!oldestDateOnPage || parsedDate < oldestDateOnPage) {
                         oldestDateOnPage = parsedDate;
                             if (isWithinRange && hasLink && !isNotice) {
                    candidateRowsRaw.push({ el, hasDate: true, parsedDate });
                  }
               } else {
                    // If no date found directly, check if it's a substantive link
                    const hasLink = $(el).find('a[href], button[onclick]').length > 0 || $(el).closest('a[href]').length > 0 || $(el).is('a[href]');
                    if (hasLink && text.trim().length > 10) {
                        candidateRowsRaw.push({ el, hasDate: false });
                    }
               }
            });

            const candidateRows = foundValidDates 
               ? candidateRowsRaw.filter(r => r.hasDate).map(r => r.el) 
               : candidateRowsRaw.map(r => r.el);

            // Extract Links from candidateRows
            let newlyAddedCount = 0;
            if (candidateRows.length > 0) {
                for (const row of candidateRows) {
                    let anchors: any = $(row).find('a, button[onclick]');
                    if (anchors.length === 0) {
                        const selfOrAncestorAnchor: any = $(row).closest('a');
                        if (selfOrAncestorAnchor.length > 0) {
                            anchors = selfOrAncestorAnchor;
                        }
                    }
                    let longestAnchor = '';
                    let longestLength = 0;
                    let longestHref = '';
                    let directDownloadUrl = '';

                    // LGBR custom AJAX post-resolution handling
                    const isLgbr = currentUrl.includes('lgbr.co.kr');
                    let lgbrIdx = '';
                    if (isLgbr) {
                        anchors.each((_, a) => {
                            const href = $(a).attr('href') || '';
                            const onclick = $(a).attr('onclick') || '';
                            const scriptCode = href.startsWith('javascript:') ? href : (onclick || '');

                            const match = scriptCode.match(/fnView\((\d+)\)/);
                            if (match && match[1]) {
                                lgbrIdx = match[1];
                            }
                        });

                        if (lgbrIdx) {
                            try {
                                const detailPostUrl = 'https://www.lgbr.co.kr/report/viewLayer.alone';
                                const agent = new https.Agent({ rejectUnauthorized: false });
                                const postRes = await axios.post(
                                    detailPostUrl,
                                    new URLSearchParams({ idx: lgbrIdx }).toString(),
                                    {
                                        headers: {
                                            'Content-Type': 'application/x-www-form-urlencoded',
                                            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
                                            'Referer': currentUrl
                                        },
                                        httpsAgent: agent,
                                        timeout: 10000
                                    }
                                );
                                if (postRes.status === 200 && postRes.data) {
                                    const $pop = cheerio.load(postRes.data);
                                    const popFileNm = $pop('#popFileNm').val() as string || '';
                                    if (popFileNm) {
                                        directDownloadUrl = popFileNm.startsWith('http') ? popFileNm : new URL(popFileNm, 'https://www.lgbr.co.kr').toString();
                                        longestHref = `https://www.lgbr.co.kr/report/viewLayer.alone?idx=${lgbrIdx}`;
                                        longestAnchor = $(row).find('strong').text().trim() || $(row).text().replace(/\s+/g, ' ').substring(0, 50).trim();
                                        longestLength = longestAnchor.length;
                                    }
                                }
                            } catch (lgbrErr: any) {
                                JobManager.addLog(jobId, 'warn', `     ⚠️ LGBR AJAX 호출 실패: ${lgbrErr.message}`);
                            }
                        }
                    }

                    if (!longestHref && !directDownloadUrl) {
                        anchors.each((_, a) => {
                            const text = $(a).text().trim();
                            const href = $(a).attr('href');
                            const onclick = $(a).attr('onclick');

                            // Ignore document viewer/popups
                            if (href && (href.includes('view.jsp') || href.includes('viewer') || href.includes('preview') || href.includes('flexer'))) return;
                            if (onclick && (onclick.includes('view.jsp') || onclick.includes('viewer') || onclick.includes('preview') || onclick.includes('flexer'))) return;

                            // Unified JS / standard URL download detection for List elements
                            if (href && !href.startsWith('javascript:') && (href.toLowerCase().endsWith('.pdf') || href.toLowerCase().endsWith('.hwp') || href.toLowerCase().endsWith('.zip'))) {
                                directDownloadUrl = href;
                            } else {
                                const scriptCode = (href && href.startsWith('javascript:')) ? href : (onclick || '');
                                if (scriptCode) {
                                    if (scriptCode.includes('filedownload')) {
                                        const m = scriptCode.match(/filedownload\([^'\"]*['"]([^'"]+)['"],\s*['"]([^'"]+)['"],\s*['"]([^'"]+)['"],\s*['"]([^'"]+)['"]\)/);
                                        if (m && m.length >= 5) {
                                            directDownloadUrl = `/common/file/userDownload?atch_no=${encodeURIComponent(m[1].replace(/&amp;/g, '&'))}&menu_cd=${m[2]}&lang=${m[3]}&no=${m[4]}`;
                                        } else {
                                            const m2 = scriptCode.match(/filedownload\([^'\"]*['"]([^'"]+)['"]\)/);
                                            if (m2 && m2[1]) directDownloadUrl = m2[1]; 
                                        }
                                    } else if (scriptCode.includes('fileDown') || scriptCode.includes('fn_egov_downFile') || scriptCode.includes('fnFileDownload') || scriptCode.includes('fncFileDownload') || scriptCode.includes('fnFileDown') || scriptCode.includes('downloadFile') || scriptCode.includes('file_down')) {
                                        const m = scriptCode.match(/(?:fileDown|fn_egov_downFile|fnFileDownload|fncFileDownload|fnFileDown|downloadFile|file_down)\(\s*['"]?([^'",\s\)]+)['"]?\s*,\s*['"]?([^'",\s\)]+)['"]?\s*(?:,\s*['"]?([^'",\s\)]*)['"]?\s*)?\)/i);
                                        if (m && m[1] && m[2]) {
                                            directDownloadUrl = `/common/cmm/fms/FileDown.do?atchFileId=${encodeURIComponent(m[1])}&fileSn=${m[2]}&bbsId=${m[3] || ''}`;
                                        }
                                    } else {
                                        const mMatch = scriptCode.match(/(?:location\.href\s*=|window\.open\s*\(\s*)['"]([^'"]+)['"]/);
                                        if (mMatch && mMatch[1]) {
                                           const extUrl = mMatch[1];
                                           if (extUrl.toLowerCase().includes('.pdf') || extUrl.toLowerCase().includes('download') || /(file\/?download|userDownload|FileDown\.do)/i.test(extUrl)) {
                                               directDownloadUrl = extUrl;
                                           }
                                        }
                                    }
                                }
                            }

                            if (text.length > longestLength) {
                                if (href && !href.startsWith('javascript:') && !href.startsWith('tel:') && !href.startsWith('mailto:')) {
                                    longestLength = text.length;
                                    longestAnchor = text;
                                    longestHref = href;
                                } else if (onclick) {
                                    // Try generic matchers for URL in onclick
                                    const m = onclick.match(/(?:location\.href\s*=|window\.open\s*\(\s*)['"]([^'"]+)['"]/);
                                    if (m && m[1]) {
                                        longestLength = text.length;
                                        longestAnchor = text;
                                        longestHref = m[1];
                                    }
                                } else if (href && href.startsWith('javascript:')) {
                                    const m = href.match(/['"](\/[^'\"]+)['"]/);
                                    if (m && m[1]) {
                                        longestLength = text.length;
                                        longestAnchor = text;
                                        longestHref = m[1];
                                    }
                                }
                            }
                        });
                    }

                    // For accordions where no detail link exists, the longest text might be just inside a toggle button/anchor.
                    // If we have a directDownloadUrl but no detail link, we must still capture the title!
                    if (!longestHref && directDownloadUrl) {
                          const titleSearchText = $(row).text().replace(/\s+/g, ' ');
                          const allTexts: string[] = [];
                          $(row).find('strong, p, div, span, a').each((_, el) => {
                              const t = $(el).text().trim();
                              if (t.length > 10 && t.length < 150) allTexts.push(t);
                          });
                          allTexts.sort((a,b) => b.length - a.length);
                          if (allTexts.length > 0) longestAnchor = allTexts[0];
                          else longestAnchor = titleSearchText.substring(0, 50).trim();
                    }

                    if (!longestAnchor && longestHref) {
                       longestAnchor = $(row).text().replace(/\s+/g, ' ').substring(0, 50).trim();
                    }

                    if (longestHref || directDownloadUrl) {
                        try {
                            const urlToUse = longestHref ? new URL(longestHref, currentUrl).toString() : currentUrl;
                            const dUrl = directDownloadUrl ? new URL(directDownloadUrl, currentUrl).toString() : undefined;
                            
                            // Check if already processed
                            const isProcessed = allCandidateDetailLinks.some(l => l.url === urlToUse);
                            if (!isProcessed) {
                                allCandidateDetailLinks.push({ title: longestAnchor, url: urlToUse, directDownloadUrl: dUrl });
                                newlyAddedCount++;
                            }
                        } catch {}
                    }
                }
            }
            
            // 만약 날짜 감지가 되는 목록인데, 이번 페이지에서 새로 추가된 정상 후보 링크가 전혀 없고 전부 중복된 링크(예: 1페이지 링크가 계속 반복되는 경우)라면,
            // 더 이상 페이지를 돌며 서버에 부하를 줄 필요가 없으므로 페이징 순회를 종료합니다. (범용 중복 순회 방지 브레이크)
            if (pIdx > 0 && newlyAddedCount === 0) {
                JobManager.addLog(jobId, 'info', `  => [Paging Break] 새로 발견된 리포트 링크가 없어 과거 페이지 순회를 종료합니다.`);
                break;
            }

            if (oldestDateOnPage && oldestDateOnPage < startParsed) {
                JobManager.addLog(jobId, 'info', `  => [Paging Break] 해당 페이지의 가장 오래된 날짜(${oldestDateOnPage.toISOString().split('T')[0]})가 조회 시작일(${startDate})보다 이전이므로 과거 페이지 조회를 종료합니다.`);
                break;
            }            JobManager.addLog(jobId, 'info', `  => [Paging Break] 새로 발견된 리포트 링크가 없어 과거 페이지 순회를 종료합니다.`);
                break;
            }

            if (oldestDateOnPage && oldestDateOnPage < startParsed) {                       if (!isProcessed) {
                                allCandidateDetailLinks.push({ title: longestAnchor, url: urlToUse, directDownloadUrl: dUrl });
                            }
                        } catch {}
                    }
                }
            }
            
            if (oldestDateOnPage && oldestDateOnPage < startParsed) {
                JobManager.addLog(jobId, 'info', `  => [Paging Break] 해당 페이지의 가장 오래된 날짜(${oldestDateOnPage.toISOString().split('T')[0]})가 조회 시작일(${startDate})보다 이전이므로 과거 페이지 조회를 종료합니다.`);
                break;
            }
        }
        
        await page.close().catch(() => {});

      } catch (err: any) {
        JobManager.addLog(jobId, 'error', `❌ 사이트 접근 실패 (${targetUrl}): ${err.message}`);
      }
    }

    JobManager.addLog(jobId, 'info', `🔍 전체 목록 수집 완료. 수집된 후보 상세 페이지 수: ${allCandidateDetailLinks.length}개`);

    // Chunk detail pages to process them in chunks
    const chunkSize = 3;
    for (let i = 0; i < allCandidateDetailLinks.length; i += chunkSize) {
        const chunk = allCandidateDetailLinks.slice(i, i + chunkSize);
        JobManager.addLog(jobId, 'info', `🔄 상세 페이지 분석 중 [Chunk ${Math.floor(i / chunkSize) + 1}/${Math.ceil(allCandidateDetailLinks.length / chunkSize)}]...`);

        await Promise.all(chunk.map(async (detail) => {
            let detailPage: any = null;
            try {
                detailPage = await browser.newPage();
                await detailPage.setUserAgent('Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36');
                await detailPage.setExtraHTTPHeaders({
                    'Accept-Language': 'ko-KR,ko;q=0.9,en-US;q=0.8,en;q=0.7'
                });
                
                let detailSuccess = false;
                let detailHtml = '';
                
                if (detail.directDownloadUrl) {
                    detailSuccess = true;
                } else {
                    for (let retry = 0; retry < 3; retry++) {
                        try {
                            await detailPage.goto(detail.url, { waitUntil: 'domcontentloaded', timeout: 30000 });
                            detailSuccess = true;
                            break;
                        } catch (detailPE) {
                            JobManager.addLog(jobId, 'warn', `     ⚠️ 상세 페이지 로드 재시도 (${retry + 1}/3): ${detail.url} - ${detailPE instanceof Error ? detailPE.message : detailPE}`);
                            await new Promise(r => setTimeout(r, 2000));
                        }
                    }
                }

                if (!detailSuccess) {
                    JobManager.addLog(jobId, 'error', `     ❌ 상세 페이지 로드 실패, 대상 스킵: ${detail.url}`);
                    return;
                }

                if (!detail.directDownloadUrl) {
                    detailHtml = await detailPage.content();
                }
                const $detail = cheerio.load(detailHtml);

                const safeTitle = detail.title.replace(/[/\\?%*:|"<>\s]/g, '_').substring(0, 100).trim() || 'Untitled';

                // Heuristic: Find Download Link
                let downloadUrl = detail.directDownloadUrl || '';
                if (!downloadUrl) {
                    $detail('a, button').each((_, el) => {
                        const text = $detail(el).text().trim();
                        const href = $detail(el).attr('href');
                        const onclick = $detail(el).attr('onclick');
                        
                        // Ignore document viewer links or preview buttons
                        if (/(미리보기|보기|뷰어|viewer|preview)/i.test(text) && !/(다운|다운로드|download)/i.test(text)) return;
                        if (href && (href.includes('view.jsp') || href.includes('flexer') || href.includes('viewer'))) return;
                        if (onclick && (onclick.includes('view.jsp') || onclick.includes('flexer') || onclick.includes('viewer'))) return;
                        
                        let rawUrl = '';
                        if (href && !href.startsWith('javascript:') && href !== '#') {
                            rawUrl = href;
                        } else {
                            const scriptCode = (href && href.startsWith('javascript:')) ? href : (onclick || '');
                            if (scriptCode) {
                                const match = scriptCode.match(/(?:location\.href\s*=\s*|window\.open\s*\(\s*)['"]([^'"]+)['"]/);
                                if (match && match[1]) {
                                    rawUrl = match[1];
                                }

                                // Generic JS download handler
                                if (!rawUrl && scriptCode.includes('filedownload')) {
                                    const m = scriptCode.match(/filedownload\([^'\"]*['"]([^'"]+)['"],\s*['"]([^'"]+)['"],\s*['"]([^'"]+)['"],\s*['"]([^'"]+)['"]\)/);
                                    if (m && m.length >= 5) {
                                        rawUrl = `/common/file/userDownload?atch_no=${encodeURIComponent(m[1].replace(/&amp;/g, '&'))}&menu_cd=${m[2]}&lang=${m[3]}&no=${m[4]}`;
                                    } else {
                                        const m2 = scriptCode.match(/filedownload\([^'\"]*['"]([^'"]+)['"]\)/);
                                        if (m2 && m2[1]) rawUrl = m2[1];
                                    }
                                }

                                // KOCCA fileDown / eGovFrame standard download handlers
                                if (!rawUrl && (scriptCode.includes('fileDown') || scriptCode.includes('fn_egov_downFile') || scriptCode.includes('fnFileDownload') || scriptCode.includes('fncFileDownload') || scriptCode.includes('fnFileDown') || scriptCode.includes('downloadFile') || scriptCode.includes('file_down'))) {
                                    const m = scriptCode.match(/(?:fileDown|fn_egov_downFile|fnFileDownload|fncFileDownload|fnFileDown|downloadFile|file_down)\(\s*['"]?([^'",\s\)]+)['"]?\s*,\s*['"]?([^'",\s\)]+)['"]?\s*(?:,\s*['"]?([^'",\s\)]*)['"]?\s*)?\)/i);
                                    if (m && m[1] && m[2]) {
                                        rawUrl = `/common/cmm/fms/FileDown.do?atchFileId=${encodeURIComponent(m[1])}&fileSn=${m[2]}&bbsId=${m[3] || ''}`;
                                    }
                                }
                            }
                        }

                        if (!rawUrl) return;

                        if (rawUrl.startsWith('tel:') || rawUrl.startsWith('mailto:')) return;

                        // Check conditions for matching attachment download URL
                        if (rawUrl.toLowerCase().includes('.pdf') || 
                            /(다운|pdf|첨부|원문|file\/?download|전체다운로드|보고서다운로드)/i.test(text) ||
                            /(file\/?download|userDownload|FileDown\.do)/i.test(rawUrl)) {
                            try {
                                downloadUrl = new URL(rawUrl, detail.url).toString();
                            } catch {}
                        }
                    });
                }

                if (downloadUrl) {
                    JobManager.addLog(jobId, 'info', `     => 첨부 링크 감지, 다운로드 실행 중... [URL: ${downloadUrl}]`);
                    try {
                        const extensionUrl = downloadUrl.toLowerCase().split('.').pop()?.split('?')[0];
                        const fallbackExtension = (extensionUrl && extensionUrl.length <= 4 && extensionUrl !== 'pdf') ? extensionUrl : 'pdf';
                        
                        const agent = new https.Agent({ rejectUnauthorized: false });
                        const response = await axios({
                            method: 'GET',
                            url: downloadUrl,
                            responseType: 'arraybuffer',
                            timeout: 15000,
                            httpsAgent: agent
                        });
                        
                        let headerExtension = '';
                        const contentDisposition = response.headers['content-disposition'];
                        if (contentDisposition) {
                            const filenameMatch = contentDisposition.match(/filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/i);
                            if (filenameMatch && filenameMatch[1]) {
                                const hdFilename = filenameMatch[1].replace(/['"]/g, '');
                                const hdExt = hdFilename.split('.').pop()?.toLowerCase();
                                if (hdExt && hdExt.length <= 4) {
                                    headerExtension = hdExt;
                                }
                            }
                        }
                        
                        const appliedExtension = headerExtension || fallbackExtension;
                        
                        if (!appliedExtension || /^(txt|png|jpg|jpeg|gif|svg|webp|html|htm|jsp|php|do|asp|aspx)$/i.test(appliedExtension)) {
                            throw new Error('Detected attachment is a web page, text, or image file, which is likely a false positive. Forcing PDF generation.');
                        }

                        const finalFileName = `${safeTitle}.${appliedExtension}`;
                        const filePath = path.join(localPath, finalFileName);
                        fs.writeFileSync(filePath, response.data);
                        JobManager.addDownloadedFile(jobId, filePath);
                        JobManager.addLog(jobId, 'success', `     ✅ 다운로드 완료 (제목 기준): ${finalFileName}`);
                    } catch (dlErr: any) {
                        JobManager.addLog(jobId, 'warn', `     ❌ 첨부 파일 다운로드 중 오류: ${dlErr.message}, 텍스트 본문 추출로 전환합니다.`);
                        downloadUrl = ''; // Force text extraction fallback
                    }
                }

                if (!downloadUrl) {
                    JobManager.addLog(jobId, 'info', `     => 첨부 없음 또는 다운로드 실패. 페이지 본문을 PDF로 변환합니다.`);
                    
                    try {
                        await detailPage.evaluate(async () => {
                            const selectorsToRemove = ['nav', 'header', 'footer', 'aside', '.gnb', '.lnb', '.pagination', '.top_menu', '.bottom_menu', '#header', '#footer'];
                            document.querySelectorAll(selectorsToRemove.join(',')).forEach(el => {
                                if (el && el.remove) el.remove();
                            });
                            
                            const images = Array.from(document.querySelectorAll('img'));
                            await Promise.all(images.map(img => {
                                if (img.complete) return Promise.resolve();
                                return new Promise(resolve => {
                                    img.onload = resolve;
                                    img.onerror = resolve;
                                    setTimeout(resolve, 3000);
                                });
                            }));
                        });

                        const filePath = path.join(localPath, `${safeTitle}.pdf`);
                        await detailPage.pdf({
                            path: filePath,
                            format: 'A4',
                            printBackground: true,
                            margin: { top: '20px', right: '20px', bottom: '20px', left: '20px' }
                        });
                        JobManager.addDownloadedFile(jobId, filePath);
                        JobManager.addLog(jobId, 'success', `     ✅ 본문 스크래핑 및 PDF 변환 완료: ${safeTitle}.pdf`);
                    } catch (pdfErr: any) {
                        JobManager.addLog(jobId, 'error', `     ❌ PDF 변환 실패: ${pdfErr.message}`);
                    }
                }
            } catch (err: any) {
                JobManager.addLog(jobId, 'error', `     ❌ 상세 페이지 처리 실패: ${detail.url} - ${err.message}`);
            } finally {
                if (detailPage) {
                    await detailPage.close().catch(() => {});
                }
            }
        }));
    }

    await browser.close();
    JobManager.addLog(jobId, 'done', `🎉 모든 크롤링 및 다운로드 작업이 성공적으로 완료되었습니다.`);

  } catch (err: any) {
    JobManager.addLog(jobId, 'error', `🔥 Job failed entirely: ${err.message}`);
  }
}
